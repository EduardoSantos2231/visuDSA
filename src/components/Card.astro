---
interface Props {
  title?: string;
  label?: string;
  date?: string;
}

const { title, label, date } = Astro.props;
---

<article class="group relative bg-card border border-border h-full overflow-hidden transition-all duration-300 hover:border-accent">
  <!-- Inner subtle grid pattern -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" 
       style="background-image: linear-gradient(rgb(255,255,255) 1px, transparent 1px), linear-gradient(90deg, rgb(255,255,255) 1px, transparent 1px); background-size: 8px 8px;">
  </div>

  <!-- Corner accents - decorative brackets like memory addresses -->
  <div class="absolute top-0 left-0 w-3 h-3 border-l-2 border-t-2 border-border/50 transition-colors duration-300 group-hover:border-accent"></div>
  <div class="absolute top-0 right-0 w-3 h-3 border-r-2 border-t-2 border-border/50 transition-colors duration-300 group-hover:border-accent"></div>
  <div class="absolute bottom-0 left-0 w-3 h-3 border-l-2 border-b-2 border-border/50 transition-colors duration-300 group-hover:border-accent"></div>
  <div class="absolute bottom-0 right-0 w-3 h-3 border-r-2 border-b-2 border-border/50 transition-colors duration-300 group-hover:border-accent"></div>

  <!-- Subtle inner glow on hover -->
  <div class="absolute inset-0 bg-accent/0 transition-all duration-300 group-hover:bg-accent/5 pointer-events-none"></div>

  <!-- Content -->
  <div class="relative z-10 p-5">
    <!-- Header with icon and label -->
    {label && (
      <div class="flex items-center gap-2 mb-3">
        <!-- Icon container with subtle background -->
        <div class="flex items-center justify-center size-8 bg-secondary/50 border border-border/50 transition-all duration-300 group-hover:border-accent/50 group-hover:bg-accent/10">
          <slot name="icon" />
        </div>
        <!-- Label as a technical tag -->
        <div class="flex items-center gap-1">
          <span class="text-[10px] text-muted-foreground/50 font-mono">0x</span>
          <h2 class="text-xs font-semibold uppercase tracking-wider text-primary font-mono">{label}</h2>
        </div>
      </div>
    )}
    
    {title && (
      <h3 class="text-xl font-medium text-primary mb-2 group-hover:text-accent transition-colors duration-300">{title}</h3>
    )}
    
    <div class="text-muted-foreground text-sm leading-relaxed">
      <slot />
    </div>
    
    {date && (
      <time class="text-xs text-muted-foreground mt-3 block font-mono">{date}</time>
    )}
  </div>

  <!-- Decorative memory address footer (only if there's content) -->
  <div class="absolute bottom-2 right-3 text-[10px] text-muted-foreground/30 font-mono select-none transition-opacity duration-300 group-hover:opacity-0">
    MEM
  </div>
</article>

<style>
  /* Sharp corners already handled by --radius: 0rem in global.css */
  
  /* Smooth transition for border color */
  article {
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  /* Enhance focus states for accessibility */
  article:focus-within {
    outline: 2px solid oklch(0.2535 0.0341 296.6556 / 0.5);
    outline-offset: 2px;
  }

  /* Subtle shadow lift on hover */
  article:hover {
    box-shadow: 0 4px 20px oklch(0 0 0 / 0.3);
  }
</style>
