---
const { class: className } = Astro.props;
---

<svg 
  class={className}
  viewBox="0 0 500 220" 
  fill="none" 
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Edges -->
  <line x1="250" y1="40" x2="160" y2="100" stroke="oklch(0.7137 0.0192 261.3246)" stroke-width="2"/>
  <line x1="250" y1="40" x2="340" y2="100" stroke="oklch(0.7137 0.0192 261.3246)" stroke-width="2"/>
  <line x1="160" y1="100" x2="80" y2="160" stroke="oklch(0.7137 0.0192 261.3246)" stroke-width="2"/>
  <line x1="160" y1="100" x2="240" y2="160" stroke="oklch(0.7137 0.0192 261.3246)" stroke-width="2"/>
  <line x1="340" y1="100" x2="420" y2="160" stroke="oklch(0.7137 0.0192 261.3246)" stroke-width="2"/>

  <!-- Nodes -->
  <!-- Root: 50 -->
  <rect x="210" y="20" width="80" height="40" rx="6" fill="oklch(0.2235 0.0049 145.4099)" stroke="oklch(0.2781 0.0296 256.8480)" stroke-width="1.5"/>
  <text x="250" y="45" text-anchor="middle" fill="oklch(1 0 0)" font-family="IBM Plex Mono, monospace" font-size="16" font-weight="600">50</text>

  <!-- Level 1 -->
  <rect x="120" y="80" width="80" height="40" rx="6" fill="oklch(0.2235 0.0049 145.4099)" stroke="oklch(0.2781 0.0296 256.8480)" stroke-width="1.5"/>
  <text x="160" y="105" text-anchor="middle" fill="oklch(1 0 0)" font-family="IBM Plex Mono, monospace" font-size="16" font-weight="600">25</text>

  <rect x="300" y="80" width="80" height="40" rx="6" fill="oklch(0.2235 0.0049 145.4099)" stroke="oklch(0.2781 0.0296 256.8480)" stroke-width="1.5"/>
  <text x="340" y="105" text-anchor="middle" fill="oklch(1 0 0)" font-family="IBM Plex Mono, monospace" font-size="16" font-weight="600">75</text>

  <!-- Level 2 - Leaves -->
  <rect x="40" y="140" width="80" height="40" rx="6" fill="oklch(0.2934 0.0547 142.3909)" stroke="oklch(0.2781 0.0296 256.8480)" stroke-width="1.5"/>
  <text x="80" y="165" text-anchor="middle" fill="oklch(1 0 0)" font-family="IBM Plex Mono, monospace" font-size="16" font-weight="600">10</text>

  <rect x="200" y="140" width="80" height="40" rx="6" fill="oklch(0.2934 0.0547 142.3909)" stroke="oklch(0.2781 0.0296 256.8480)" stroke-width="1.5"/>
  <text x="240" y="165" text-anchor="middle" fill="oklch(1 0 0)" font-family="IBM Plex Mono, monospace" font-size="16" font-weight="600">33</text>

  <rect x="380" y="140" width="80" height="40" rx="6" fill="oklch(0.2934 0.0547 142.3909)" stroke="oklch(0.2781 0.0296 256.8480)" stroke-width="1.5"/>
  <text x="420" y="165" text-anchor="middle" fill="oklch(1 0 0)" font-family="IBM Plex Mono, monospace" font-size="16" font-weight="600">90</text>

  <!-- Labels - corrigidos -->
  <text x="250" y="12" text-anchor="middle" fill="oklch(0.7137 0.0192 261.3246)" font-family="Inter, sans-serif" font-size="11">raiz</text>
  <text x="30" y="155" text-anchor="middle" fill="oklch(0.7137 0.0192 261.3246)" font-family="Inter, sans-serif" font-size="11">folhas</text>
</svg>
