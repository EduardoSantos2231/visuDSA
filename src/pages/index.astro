---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { GraduationCap, Binary, Database, ArrowDown, Eye, Brain, Zap, Search, Code2, Cpu, Layers, Hash } from '@lucide/astro';

const navItems = [
  { content: "Introdução", link: "/visuDSA/introducao", Icon: GraduationCap, label: "Aprenda os conceitos fundamentais" },
  { content: "Algoritmos", link: "/visuDSA/algoritmos", Icon: Binary, label: "Visualize algoritmos em ação" },
  { content: "E. de dados", link: "/visuDSA/estrutura-de-dados", Icon: Database, label: "Explore estruturas de dados" },
];

const floatingElements = [
  { char: '{', x: '10%', y: '20%', delay: '0s' },
  { char: '}', x: '85%', y: '15%', delay: '0.5s' },
  { char: '[', x: '75%', y: '70%', delay: '1s' },
  { char: ']', x: '20%', y: '75%', delay: '1.5s' },
  { char: 'O(1)', x: '60%', y: '30%', delay: '0.3s' },
  { char: 'n²', x: '30%', y: '45%', delay: '0.8s' },
  { char: 'log', x: '80%', y: '50%', delay: '1.2s' },
  { char: '→', x: '45%', y: '80%', delay: '0.6s' },
  { char: '<>', x: '15%', y: '55%', delay: '1.8s' },
  { char: '42', x: '70%', y: '35%', delay: '2s' },
  { char: '99', x: '25%', y: '25%', delay: '0.4s' },
  { char: '▲', x: '55%', y: '65%', delay: '1.4s' },
];

const algorithmCards = [
  { Icon: Search, title: "Busca", desc: "Linear & Binária" },
  { Icon: Layers, title: "Ordenação", desc: "Bubble, Quick, Merge" },
  { Icon: Hash, title: "Grafos", desc: "DFS, BFS, Dijkstra" },
  { Icon: Cpu, title: "Recursão", desc: "Fibonacci, Backtracking" },
];
---

<Layout title="Home">
  <Header />
  <div class="flex flex-col">
    <!-- Seção Hero: Título + Navegação -->
    <section class="min-h-[calc(100vh-4rem)] flex flex-col justify-center items-center px-4 relative overflow-hidden">
      <!-- Animated Background Elements -->
      <div class="hero-bg" aria-hidden="true">
        {floatingElements.map((el) => (
          <span class="floating-char" style={`left: ${el.x}; top: ${el.y}; animation-delay: ${el.delay};`}>
            {el.char}
          </span>
        ))}
        
        <!-- Grid pattern overlay -->
        <div class="hero-grid"></div>
        
        <!-- Animated sorting bars (subtle) -->
        <div class="sorting-viz">
          {Array.from({ length: 20 }).map((_, i) => (
            <div class="sort-bar" style={`height: ${20 + Math.random() * 60}%; animation-delay: ${i * 0.1}s;`}></div>
          ))}
        </div>
      </div>

      <!-- Hero Content -->
      <div class="hero-content relative z-10 text-center">
        
        
        <h1 id="main_title" class="hero-title">
          <span class="title-line inline-block opacity-0 animate-slide-up" style="animation-delay: 0.1s;">Visu</span>
          <span class="title-accent inline-block opacity-0 animate-slide-up" style="animation-delay: 0.2s;">DSA</span>
        </h1>
        
        <p class="hero-subtitle opacity-0 animate-fade-in" style="animation-delay: 0.4s;">
          Veja algoritmos e estruturas de dados em ação
        </p>
        
        <nav class="flex flex-wrap justify-center gap-3 md:gap-4 mt-10" aria-label="Navegação rápida">
          {navItems.map((item, index) => (
            <a 
              href={item.link} 
              aria-label={item.label}
              class="nav-btn opacity-0 animate-fade-in group"
              style={`animation-delay: ${0.5 + index * 0.1}s;`}
            >
              <span class="nav-btn-bg"></span>
              <span class="nav-btn-glow"></span>
              <span class="nav-btn-content">
                <item.Icon class="size-4" aria-hidden="true" />
                <span>{item.content}</span>
              </span>
            </a>
          ))}
        </nav>
      </div>

      <!-- Algorithm Preview Cards (decorative) -->
      <div class="hero-cards hidden lg:flex absolute bottom-24 left-1/2 -translate-x-1/2 gap-4 opacity-0 animate-fade-in" style="animation-delay: 0.8s;">
        {algorithmCards.map((card) => (
          <div class="hero-card group">
            <div class="hero-card-glow"></div>
            <card.Icon class="size-5" />
            <div>
              <div class="hero-card-title">{card.title}</div>
              <div class="hero-card-desc">{card.desc}</div>
            </div>
          </div>
        ))}
      </div>

      <!-- Indicador de Scroll -->
      <div class="absolute bottom-6 md:bottom-8 z-10" aria-hidden="true">
        <div class="scroll-indicator">
          <ArrowDown class="size-5 text-muted-foreground" />
        </div>
      </div>
    </section>

    <!-- Decorative Section Divider -->
    <div class="section-divider" aria-hidden="true">
      <div class="divider-line"></div>
            <div class="divider-line"></div>
    </div>

    <!-- Seção: Por que estudar algoritmos? -->
    <section class="px-4 py-20 md:py-32 max-w-4xl mx-auto">
      <div class="scroll-content slide-left">
        <div class="section-header">
          <span class="section-number">01</span>
          <h2 class="section-title">Por que estudar algoritmos?</h2>
        </div>
        <p>
          Algoritmos são a base de praticamente tudo o que acontece em software. Sempre que um programa precisa buscar dados, ordenar informações ou processar grandes volumes de entrada, existe um algoritmo por trás tomando essas decisões.
        </p>
        <p>
          Entender algoritmos não é apenas um exercício acadêmico. Na prática, esse conhecimento permite escrever programas <strong>mais eficientes, mais escaláveis e mais previsíveis</strong>. A diferença entre duas soluções para o mesmo problema pode significar um sistema que responde instantaneamente ou um sistema que se torna lento à medida que cresce.
        </p>
        <p>
          Além disso, algoritmos e estruturas de dados são um dos temas mais cobrados em <strong>entrevistas técnicas de engenharia de software</strong>. Muitas empresas utilizam esses problemas para avaliar raciocínio lógico, capacidade de resolução de problemas e domínio dos fundamentos da computação.
        </p>
        <p>
          Dominar esses conceitos não apenas melhora sua capacidade de resolver problemas, mas também fortalece sua base como desenvolvedor.
        </p>
      </div>
    </section>

    <!-- Decorative Section Divider -->
    <div class="section-divider" aria-hidden="true">
      <div class="divider-line"></div>
            <div class="divider-line"></div>
    </div>

    <!-- Seção: Para que serve esta aplicação? -->
    <section class="px-4 py-20 md:py-32 max-w-4xl mx-auto">
      <div class="scroll-content slide-right">
        <div class="section-header">
          <span class="section-number">02</span>
          <h2 class="section-title">Para que serve esta aplicação?</h2>
        </div>
        <p>
          Esta aplicação foi criada para tornar o estudo de algoritmos <strong>mais visual e intuitivo</strong>.
        </p>
        <p>Aqui você poderá:</p>
        <ul class="feature-list">
          <li><Eye class="feature-icon" /> visualizar o funcionamento de algoritmos passo a passo</li>
          <li><Brain class="feature-icon" /> entender como estruturas de dados se comportam internamente</li>
          <li><Zap class="feature-icon" /> testar operações e observar como elas afetam a complexidade do algoritmo</li>
          <li><Search class="feature-icon" /> explorar conceitos fundamentais de forma interativa</li>
        </ul>
        <p>
          O objetivo é reduzir a distância entre <strong>teoria e prática</strong>, permitindo que você veja <strong>uma representação visual do que acontece</strong> quando um algoritmo é executado.
        </p>
      </div>
    </section>

    <!-- Decorative Section Divider -->
    <div class="section-divider" aria-hidden="true">
      <div class="divider-line"></div>
            <div class="divider-line"></div>
    </div>

    <!-- Seção: Aviso importante -->
    <section class="px-4 py-20 md:py-32 max-w-4xl mx-auto">
      <div class="scroll-content fade">
        <div class="notice-box">
          <div class="notice-header">
            <span class="notice-icon">i</span>
            <h2 class="section-title">Aviso importante</h2>
          </div>
          <p>
            O conteúdo apresentado aqui tem como objetivo <strong>introduzir os principais conceitos de algoritmos e estruturas de dados</strong>.
          </p>
          <p>
            Esta aplicação não substitui um estudo aprofundado do tema. Algoritmos são um campo amplo da ciência da computação, e compreender plenamente suas aplicações exige prática, leitura e experimentação contínua.
          </p>
          <p>
            Use esta ferramenta como um <strong>ponto de partida para construir uma base sólida</strong>, e continue explorando os conceitos em maior profundidade ao longo da sua jornada de aprendizado.
          </p>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <Footer />
  </div>
</Layout>

<style>
@import url('https://fonts.googleapis.com/css2?family=Bitcount+Grid+Double:wght@100..900&display=swap');

/* Hero Styles */
.hero-bg {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
}

.floating-char {
  position: absolute;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 1.25rem;
  color: oklch(0.35 0.06 290 / 0.3);
  animation: float 8s ease-in-out infinite;
  user-select: none;
}

@keyframes float {
  0%, 100% { 
    transform: translateY(0) rotate(0deg); 
    opacity: 0.3;
  }
  50% { 
    transform: translateY(-20px) rotate(5deg); 
    opacity: 0.6;
  }
}

.hero-grid {
  position: absolute;
  inset: 0;
  background-image: 
    linear-gradient(oklch(0.28 0.03 256 / 0.05) 1px, transparent 1px),
    linear-gradient(90deg, oklch(0.28 0.03 256 / 0.05) 1px, transparent 1px);
  background-size: 40px 40px;
  mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 70%);
}

.sorting-viz {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 40%;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 4px;
  padding: 0 10%;
  opacity: 0.15;
}

.sort-bar {
  flex: 1;
  max-width: 20px;
  background: linear-gradient(to top, oklch(0.55 0.12 280), oklch(0.35 0.08 280));
  animation: sort-pulse 3s ease-in-out infinite;
}

@keyframes sort-pulse {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 0.8; }
}

/* Hero Content */
.hero-content {
  text-align: center;
  max-width: 800px;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 1rem;
  background: oklch(0.22 0.04 296 / 0.3);
  border: 1px solid oklch(0.35 0.06 290);
  border-radius: 9999px;
  font-size: 0.75rem;
  color: oklch(0.75 0.02 270);
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.hero-title {
  font-family: "Bitcount Grid Double", system-ui;
  font-optical-sizing: auto;
  font-weight: 200;
  font-style: normal;
  font-variation-settings:
    "slnt" 0,
    "CRSV" 0.5,
    "ELSH" 0,
    "ELXP" 0;
  font-size: clamp(3rem, 12vw, 6rem);
  line-height: 1.1;
  margin: 0;
}

.title-accent {
  color: oklch(0.65 0.12 280);
  transition: text-shadow 0.3s ease;
}

.title-accent:hover {
  text-shadow: 0 0 20px oklch(0.65 0.12 280 / 0.5), 0 0 40px oklch(0.65 0.12 280 / 0.3);
}

.hero-subtitle {
  margin-top: 1rem;
  font-size: 1.125rem;
  color: oklch(0.71 0.02 261);
  letter-spacing: 0.02em;
}

/* Navigation Buttons */
.nav-btn {
  position: relative;
  display: inline-block;
  border-radius: 0;
  overflow: hidden;
}

.nav-btn-glow {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, transparent 0%, rgba(255,255,255,0.03) 50%, transparent 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.nav-btn:hover .nav-btn-glow {
  opacity: 1;
}

.nav-btn-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, oklch(0.22 0.04 296) 0%, oklch(0.18 0.03 280) 100%);
  border: 1px solid oklch(0.35 0.06 290);
  transition: all 0.3s ease;
}

.nav-btn:hover .nav-btn-bg {
  background: linear-gradient(135deg, oklch(0.25 0.04 296) 0%, oklch(0.2 0.03 280) 100%);
  border-color: oklch(1 0 0 / 0.3);
  box-shadow: 0 0 20px oklch(1 0 0 / 0.1), 0 0 30px oklch(0.15 0.02 300 / 0.1);
}

.nav-btn-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem 1.25rem;
  color: oklch(0.71 0.02 261);
  font-size: 0.875rem;
  transition: color 0.3s ease;
}

.nav-btn:hover .nav-btn-content {
  color: oklch(0.92 0.01 145);
}

/* Hero Cards */
.hero-cards {
  position: absolute;
  bottom: 6rem;
}

.hero-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.75rem 1rem;
  background: oklch(0.18 0.03 280 / 0.6);
  border: 1px solid oklch(0.28 0.03 256);
  color: oklch(0.71 0.02 261);
  overflow: hidden;
  transition: all 0.3s ease;
}

.hero-card-glow {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, transparent 0%, rgba(255,255,255,0.03) 50%, transparent 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.hero-card:hover {
  border-color: oklch(1 0 0 / 0.3);
  box-shadow: 0 0 20px oklch(1 0 0 / 0.1), 0 0 30px oklch(0.15 0.02 300 / 0.1);
  transform: translateY(-2px);
}

.hero-card:hover .hero-card-glow {
  opacity: 1;
}

.hero-card-title {
  font-size: 0.75rem;
  font-weight: 600;
  color: oklch(0.92 0.01 145);
}

.hero-card-desc {
  font-size: 0.625rem;
  color: oklch(0.56 0.02 261);
}

/* Scroll Indicator */
.scroll-indicator {
  animation: scroll-bounce 2s ease-in-out infinite;
}

@keyframes scroll-bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(8px); }
}

/* Section Divider */
.section-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  padding: 0 2rem;
  max-width: 600px;
  margin: 0 auto;
}

.divider-line {
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, transparent, oklch(0.28 0.03 256), transparent);
}

.divider-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 2rem;
  height: 2rem;
  background: oklch(0.18 0.03 280);
  border: 1px solid oklch(0.28 0.03 256);
  color: oklch(0.56 0.02 261);
}

/* Content Sections */
.section-header {
  display: flex;
  align-items: baseline;
  gap: 1rem;
  margin-bottom: 2rem;
}

.section-number {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.75rem;
  color: oklch(0.42 0.09 141);
  letter-spacing: 0.1em;
}

.section-title {
  font-family: "Bitcount Grid Double", system-ui;
  font-optical-sizing: auto;
  font-weight: 400;
  font-style: normal;
  font-variation-settings:
    "slnt" 0,
    "CRSV" 0.5,
    "ELSH" 0,
    "ELXP" 0;
  font-size: 1.75rem;
  color: var(--primary);
  margin: 0;
}

.scroll-content {
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 0.8s ease-out, transform 0.8s ease-out;
}

.scroll-content.visible {
  opacity: 1;
  transform: translateY(0);
}

.slide-left {
  transform: translateX(-40px);
}

.slide-right {
  transform: translateX(40px);
}

.fade {
  transform: translateY(40px);
}

.scroll-content p {
  color: var(--muted-foreground);
  line-height: 1.8;
  margin-bottom: 1.25rem;
  text-align: justify;
}

.scroll-content p:last-child {
  margin-bottom: 0;
}

.scroll-content strong {
  color: var(--foreground);
  font-weight: 600;
}

/* Feature List */
.feature-list {
  list-style: none;
  padding: 0;
  margin: 1.5rem 0;
}

.feature-list li {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  margin-bottom: 1rem;
  color: var(--muted-foreground);
  line-height: 1.6;
}

.feature-icon {
  flex-shrink: 0;
  width: 1.25rem;
  height: 1.25rem;
  color: var(--accent);
  margin-top: 0.1rem;
}

/* Notice Box */
.notice-box {
  background: linear-gradient(135deg, oklch(0.22 0.04 296) 0%, oklch(0.18 0.03 280) 100%);
  border: 1px solid oklch(0.35 0.06 290);
  border-radius: 0;
  padding: 2rem;
}

.notice-header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
}

.notice-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 1.5rem;
  height: 1.5rem;
  background: oklch(0.35 0.06 290);
  border-radius: 0;
  font-family: "Bitcount Grid Double", system-ui;
  font-size: 0.875rem;
  font-weight: 600;
  color: oklch(0.95 0.01 90);
}

.notice-box .section-title {
  color: oklch(0.9 0.02 90);
  margin: 0;
}

.notice-box p {
  color: oklch(0.75 0.02 270);
  line-height: 1.8;
  margin-bottom: 1.25rem;
}

.notice-box p:last-child {
  margin-bottom: 0;
}

.notice-box strong {
  color: oklch(0.95 0.01 90);
}

/* Animations */
@keyframes fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slide-up {
  from { 
    opacity: 0;
    transform: translateY(20px);
  }
  to { 
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-fade-in {
  animation: fade-in 0.6s ease-out forwards;
}

.animate-slide-up {
  animation: slide-up 0.6s ease-out forwards;
}

/* Responsive */
@media (min-width: 768px) {
  .section-title {
    font-size: 2.25rem;
  }
  
  .section-header {
    gap: 1.5rem;
  }
  
  .section-number {
    font-size: 0.875rem;
  }
}

@media (max-width: 1023px) {
  .hero-cards {
    display: none;
  }
}
</style>

<script>
  // Scroll animations
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });

  document.querySelectorAll('.scroll-content').forEach(el => {
    observer.observe(el);
  });
</script>
