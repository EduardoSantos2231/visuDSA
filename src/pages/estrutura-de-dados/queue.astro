---
import Layout from '../../layouts/Layout.astro';
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="Queue - Estrutura de Dados">
  <Header />
  <main class="px-4 py-8 max-w-4xl mx-auto">
    <section class="mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-primary mb-4">Queue (Fila)</h1>
      <p class="text-muted-foreground text-lg text-justify leading-relaxed">
        Esta página está em desenvolvimento. Em breve, haverá conteúdo sobre filas.
      </p>
    </section>
  </main>
  <Footer />
</Layout>
